# Copy to .env and adjust. Never commit real secrets.

# Local / production: PostgreSQL (e.g. Neon — use pooled connection string on Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-32-plus-random-characters-for-production"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# Public site contact & social (optional). Shown in footer, support/careers/DPO pages.
NEXT_PUBLIC_CONTACT_EMAIL="contact@example.com"
NEXT_PUBLIC_JOBS_EMAIL="careers@example.com"
NEXT_PUBLIC_DPO_EMAIL="dpo@example.com"
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL="https://www.facebook.com/your-page"
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL="https://www.youtube.com/@your-channel"
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL="https://www.tiktok.com/@your-account"
