generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         String    @default("user")
  vipUntil     DateTime?
  createdAt    DateTime  @default(now())
}

model Movie {
  id               String      @id @default(cuid())
  bookId           String
  slug             String
  title            String
  synopsis         String      @default("")
  episodes         Int
  tag              String?
  posterSrc        String
  kind             String      @default("SINGLE")
  playbackType     String?
  playbackUrl      String?
  exclusive        Boolean     @default(false)
  status           String      @default("DRAFT")
  showCarousel     Boolean     @default(false)
  showRecommended  Boolean     @default(false)
  showTrending     Boolean     @default(false)
  showHidden       Boolean     @default(false)
  shelfOrder       Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  episodesRel      Episode[]

  @@unique([bookId, slug])
  @@index([status])
}

model Episode {
  id           String   @id @default(cuid())
  movieId      String
  number       Int
  title        String?
  thumbnail    String?
  playbackType String?
  playbackUrl  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  movie        Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([movieId, number])
  @@index([movieId])
}
